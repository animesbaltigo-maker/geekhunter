# Telegram
TELEGRAM_BOT_TOKEN=cole_o_token_do_botfather
TELEGRAM_CHANNEL_ID=@seu_canal_ou_-100xxxxxxxxxx
ADMIN_TELEGRAM_ID=
OWNER_TELEGRAM_ID=
HEALTH_PORT=8080

# Seguranca: deixe true enquanto estiver testando.
# Para postar de verdade, use DRY_RUN=false ou rode: python bot.py --once --post
DRY_RUN=true

# Use true para testar o pipeline completo sem token do Mercado Livre.
USE_SAMPLE_DATA=false
# Opcoes de autopost:
# panel = Mercado Livre pelo painel
# promotions = promocoes oficiais do Mercado Livre
# Shopee fica somente para links enviados manualmente no bot multiusuario.
PRODUCT_SOURCE=panel
PANEL_CDP_URL=http://127.0.0.1:9222
SHOPEE_PANEL_URL=https://affiliate.shopee.com.br/offer/product_offer
SHOPEE_PANEL_CDP_URL=http://127.0.0.1:9222
BROWSER_PROFILE_DIR=browser_profile/ml_affiliate
BROWSER_HEADLESS=false
PROMOTION_TYPES=DOD,LIGHTNING,DEAL

# Mercado Livre
# O token e opcional para buscas publicas, mas ajuda se voce evoluir para rotas autenticadas.
ML_APP_ID=
ML_SECRET_KEY=
ML_REDIRECT_URI=
ML_ACCESS_TOKEN=
ML_REFRESH_TOKEN=
ML_USER_ID=

# Etiqueta em uso no painel de afiliados.
# O bot nao depende de cookies. O melhor caminho e usar o link/template oficial do painel de afiliados.
ML_AFFILIATE_LABEL_ID=

# Se o painel do ML te der um formato de deeplink, coloque aqui.
# Placeholders aceitos: {url}, {encoded_url}, {item_id}, {affiliate_id}, {label_id}
# Exemplo ficticio:
# AFFILIATE_URL_TEMPLATE=https://seudominio-ou-rede.com/deeplink?u={encoded_url}&aff={affiliate_id}
AFFILIATE_LINK_MODE=template
AFFILIATE_URL_TEMPLATE=

# Experimental: se quiser testar link direto com parametros matt_* no permalink.
# Use apenas depois de validar que o Mercado Livre atribui clique/venda no painel.
ML_AFFILIATE_MATT_TOOL=93444346

# Curadoria
SEARCH_TERMS=ofertas do dia,smartphone,iphone,xiaomi,samsung,fone bluetooth,headset gamer,caixa de som bluetooth,smartwatch,carregador iphone,carregador usb c,power bank,notebook,monitor gamer,teclado mecanico,mouse gamer,ssd,tablet,impressora,air fryer,cafeteira,liquidificador,panela eletrica,chaleira eletrica,cozinha,casa,organizadores,cama mesa banho,travesseiro,colchao,ferramentas,furadeira,parafusadeira,kit ferramentas,tenis masculino,tenis feminino,tenis adidas,tenis nike,camiseta,jaqueta,bolsa feminina,relogio,perfume,maquiagem,skincare,creatina,whey protein,suplementos,vitaminas,brinquedos,lego,funko pop,pet shop,racao,livros,manga,games,controle ps5,cadeira gamer,bebes,fralda,material escolar,mochila,auto pecas,acessorios carro,bicicleta,camping,jardim,piscina
CATEGORY_IDS=MLB1051,MLB1648,MLB1574,MLB1196,MLB1144
MIN_DISCOUNT_PCT=10
MIN_SOLD_QUANTITY=0
MIN_RATING=0
MAX_PRICE=
BLOCKED_WORDS=
POSTS_PER_ROUND=1
NICHE_ROTATE_MIN_POSTS=3
NICHE_ROTATE_MAX_POSTS=5
ROUND_INTERVAL_MINUTES=10

# IA
# AI_PROVIDER pode ser: fallback, groq, anthropic, openai
# fallback nao usa API paga: gera texto simples localmente.
AI_PROVIDER=groq
GROQ_API_KEY=
AI_MODEL=llama-3.3-70b-versatile
POST_EMOJIS=true
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Internos
HISTORY_PATH=data/posted_items.json
REQUEST_TIMEOUT=20
MULTIUSER_BROWSER_FALLBACK=false

# Rate limiting do bot multiusuario
USER_POST_COOLDOWN_SECONDS=60
USER_POSTS_PER_HOUR=20
FREE_MAX_CHANNELS=1
FREE_POSTS_PER_DAY=20
PRO_MAX_CHANNELS=0
PRO_POSTS_PER_DAY=0
MAX_CHANNELS_FREE=3
TOKEN_AUTO_REFRESH=true

# Inteligencia de produto e alertas
PRICE_HISTORY_ENABLED=true
PRICE_ALERT_CHECK_INTERVAL=30
MAX_ALERTS_FREE=5
MAX_ALERTS_PRO=20

# Conteudo automatico
DAILY_SUMMARY_ENABLED=true
DAILY_SUMMARY_HOUR=23
WEEKLY_NICHE_SCHEDULE=
CURATION_MODE=false
SILENT_HOURS=
BLACKLIST_TERMS=

# Integracoes e relatorios
OUTGOING_WEBHOOK_URL=
OUTGOING_WEBHOOK_SECRET=
RSS_ENABLED=false
RSS_PORT=8081
WEEKLY_REPORT_ENABLED=true

# Mockup vertical 1080x1350 para posts de oferta
OFFER_MOCKUP_ENABLED=true
OFFER_MOCKUP_BRAND=@GeekHunter_Br
OFFER_MOCKUP_BACKGROUND_URL=https://i.ibb.co/6R41sKyG/Chat-GPT-Image-13-de-mai-de-2026-21-16-28.png
